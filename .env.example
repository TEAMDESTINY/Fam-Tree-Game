# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Telegram API credentials (from https://my.telegram.org)
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Bot owner/admin user ID
OWNER_ID=your_user_id

# Tomato soup owner user id
TOMATO_SOUP_COMMISSION_USER_ID=who_you_want_to_own_tomato_soup_id

# Database URL (required)
# Example: postgresql://user:password@localhost:5432/famtree
DATABASE_URL=postgresql://famtree:famtree_secret@localhost:5432/famtree

# Pexels API Key (for 4-pic game)
# Get from: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Logging level (optional, default: INFO)
# LOG_LEVEL=DEBUG
